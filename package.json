{
  "name": "blink-share",
  "version": "1.0.0",
  "description": "Decentralized temporary file sharing on Shelby hot storage",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "compile": "npx hardhat compile",
    "test:contracts": "npx hardhat test",
    "deploy:local": "npx hardhat node & sleep 2 && npx hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "backend": "cd backend && npm start",
    "frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0"
  }
}
