# ─────────────────────────────────────────────────────────────────────────────
#  Blink Share — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Shelby / Geomi API Keys ───────────────────────────────────────────────────
#
# Acquire your API keys at https://geomi.dev:
#   1. Log in or create an account at https://geomi.dev
#   2. Click "API Resource" on the overview page
#   3. Configure: Network = Testnet, add a name and usage description
#   4. Submit — your key is generated instantly (format: aptoslabs_***)
#
#   Key types:
#     Private key  -> for server-side/Node.js use (SHELBY_API_KEY below)
#     Client key   -> for browser/frontend use  (SHELBY_CLIENT_KEY below)
#                     Generate a separate "client key" in the same Geomi UI
#
#   More info: https://geomi.dev/docs/api-keys | https://geomi.dev/docs/admin/billing
#
# Server-side private API key (used by Node.js backend / ShelbyNodeClient)
SHELBY_API_KEY=aptoslabs_your_private_key_here

# Client-side key exposed to the browser (safe to embed in frontend JS)
# Generate this separately in Geomi: same steps, click "Create client key"
SHELBY_CLIENT_KEY=aptoslabs_your_client_key_here

# Shelby network: "testnet" (default) | "mainnet" | "devnet"
SHELBY_NETWORK=testnet

# Optional: fallback replica gateway URL for download redundancy
SHELBY_REPLICA=

# Request timeout in ms (default 30000)
SHELBY_TIMEOUT=30000

# Set to "true" for local dev without a real Shelby node or API key
# Files are stored in memory only — nothing persists between restarts
SHELBY_MOCK=true


# ── Blockchain ────────────────────────────────────────────────────────────────
# RPC endpoint for reading contract state
RPC_URL=http://127.0.0.1:8545

# Deployed BlinkShare contract address (set after running deploy script)
CONTRACT_ADDRESS=0xYourContractAddressHere

# Deployer / backend signer private key (KEEP SECRET — testnet wallet only)
DEPLOYER_PRIVATE_KEY=0xYourPrivateKeyHere
BACKEND_PRIVATE_KEY=0xYourPrivateKeyHere

# Sepolia RPC (e.g. Alchemy or Infura endpoint)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key for contract source verification (optional)
ETHERSCAN_API_KEY=


# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000

# Maximum file upload size in bytes (default 100 MB)
MAX_FILE_SIZE=104857600


# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# Set to "true" when running behind HTTPS (required for Web Crypto API in prod)
HTTPS=false
